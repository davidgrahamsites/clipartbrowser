{
  "name": "clipartbrowser-windows",
  "productName": "ClipartBrowser CN",
  "version": "0.2.2",
  "description": "Windows (Electron) edition of ClipartBrowser — Simplified Chinese",
  "author": "ClipartBrowser",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidgrahamsites/clipartbrowser.git"
  },
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --publish never"
  },
  "build": {
    "appId": "local.clipartbrowser.windows.zh",
    "productName": "ClipartBrowser CN",
    "directories": {
      "output": "dist"
    },
    "publish": null,
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^31.7.6",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "image-size": "^1.1.1",
    "jszip": "^3.10.1",
    "pica": "^9.0.1",
    "pdfjs-dist": "^3.11.174",
    "tesseract.js": "^5.1.1"
  }
}
